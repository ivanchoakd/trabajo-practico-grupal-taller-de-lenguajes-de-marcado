program {
    DibujarRelojAnalógicoSimplificado()
}

procedure DibujarRelojAnalógicoSimplificado() {
    /*
    Proposito:
    Precondicion:
    Observacion:
    */
    IrAPrimeraPosicion()
    DibujarNumeroDoce()
    IrASegundaPosicion()
    DibujarNumeroTres()
    IrATerceraPosicion()
    DibujarNumeroSeis()
    IrACuartaPosicion()
    DibujarNumeroNueve()
    VolverAlInicio()
}

procedure IrAPrimeraPosicion() {
    /**/
    repeat(4) {
        Mover(Norte)}
    repeat(2) {
        Mover(Este)}
}

procedure DibujarNumeroDoce() {
    /**/
    repeat(12) {
        Poner(Rojo)
    }
}

procedure IrASegundaPosicion() {
    /**/
    repeat(2) {
        Mover(Este)}
    repeat(2) {
        Mover(Sur)
    }
}

procedure DibujarNumeroTres() {
    /**/
    repeat(3) {
        Poner(Rojo)
    }
}

procedure IrATerceraPosicion() {
    /**/
    repeat(2) {
        Mover(Sur)
        Mover(Oeste)
    }
}

procedure DibujarNumeroSeis() {
    /**/
    repeat(6) {
        Poner(Rojo)
    }
}

procedure IrACuartaPosicion() {
    /**/
    repeat(2) {
        Mover(Oeste)
        Mover(Norte)
    }
}

procedure DibujarNumeroNueve() {
    /**/
    repeat(9) {
        Poner(Rojo)
    }
}

procedure VolverAlInicio() {
    /**/
    repeat(2) {
        Mover(Este)
    }
}